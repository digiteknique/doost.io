---
import type { LinkEntry } from '../data/links';

interface Props {
  links: LinkEntry[];
}

const { links } = Astro.props;
---

<nav class="links-row" aria-label="Elsewhere">
  {links.map((link) => (
    <a href={link.href} title={link.label} aria-label={link.label}>
      {link.icon === 'github' && (
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.333-1.755-1.333-1.755-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.775.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
      )}
      {link.icon === 'linkedin' && (
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.114 20.452H3.558V9h3.556v11.452z" /></svg>
      )}
      {link.icon === 'instagram' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      )}
      {link.icon === 'threads' && (
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717-1.34 1.67-2.033 4.078-2.06 7.163.027 3.086.72 5.493 2.06 7.163 1.43 1.781 3.63 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.732 1.79-1.202.065-2.365-.218-3.277-.795-1.075-.68-1.72-1.716-1.816-2.916-.19-2.372 1.622-4.08 4.61-4.253.905-.053 1.755-.045 2.535.024-.113-.76-.35-1.35-.71-1.756-.492-.555-1.243-.836-2.235-.836h-.017c-.796.006-1.87.226-2.55 1.222l-1.75-1.196c.964-1.42 2.533-2.204 4.32-2.212h.02c2.53.01 4.028 1.585 4.184 4.373.09.033.18.067.267.104 1.376.575 2.398 1.44 2.955 2.502.797 1.52.845 3.988-1.223 5.99-1.665 1.607-3.68 2.406-6.35 2.427h-.005z" /></svg>
      )}
      {link.icon === 'email' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      )}
    </a>
  ))}
</nav>

<style>
  .links-row {
    display: flex;
    gap: 10px;
  }
  .links-row a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--line);
    border-radius: 2px;
    color: var(--text-dim);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .links-row a:hover,
  .links-row a:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
