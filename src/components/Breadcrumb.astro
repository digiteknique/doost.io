---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  {items.map((item, i) => (
    <Fragment>
      {i > 0 && <span class="sep" aria-hidden="true">/</span>}
      {item.href ? <a href={item.href}>{item.label}</a> : <span class="current" aria-current="page">{item.label}</span>}
    </Fragment>
  ))}
</nav>

<style>
  .breadcrumb {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin: 0 0 20px;
  }
  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
  }
  .breadcrumb a:hover,
  .breadcrumb a:focus-visible {
    color: var(--accent);
  }
  .sep {
    color: var(--line);
  }
  .current {
    color: var(--text);
  }
</style>
