---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  widths = [400, 800, 1200],
  sizes = '(min-width: 700px) 640px, 100vw',
} = Astro.props;
---

<figure>
  <Image src={src} alt={alt} widths={widths} sizes={sizes} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
