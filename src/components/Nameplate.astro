---
interface Props {
  name: string;
  tagline: string;
  bio: string;
}

const { name, tagline, bio } = Astro.props;
---

<header class="nameplate">
  <h1>{name}</h1>
  <div class="meta-line">{tagline}<span class="cursor"></span></div>
  <p class="bio">{bio}</p>
</header>

<style>
  .nameplate {
    border-bottom: 1px solid var(--line);
    padding-bottom: 24px;
    margin-bottom: 28px;
  }

  h1 {
    font-family: var(--mono);
    font-size: clamp(28px, 4vw, 34px);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 10px;
    text-wrap: balance;
  }

  .meta-line {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 14px;
    background: var(--accent);
    margin-left: 4px;
    animation: blink 1.1s steps(1) infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
      opacity: 0.7;
    }
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .bio {
    max-width: 62ch;
    color: var(--text);
    font-size: 16px;
    margin: 18px 0 0;
  }
</style>
