---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import SectionLabel from '../../../components/SectionLabel.astro';
import LogList from '../../../components/LogList.astro';
import TagChips from '../../../components/TagChips.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

  return tags.map((tag) => {
    const matching = posts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .map((post) => ({
        date: post.data.date,
        title: post.data.title,
        href: `/blog/${post.id}/`,
      }));
    return { params: { tag }, props: { tag, posts: matching, allTags: tags } };
  });
}

const { tag, posts, allTags } = Astro.props;
---

<Layout title={`Tagged “${tag}” — doost.io`} description={`Posts tagged ${tag}.`}>
  <section aria-label={`Posts tagged ${tag}`}>
    <SectionLabel text={`log / ${tag}`} />
    <TagChips tags={allTags} active={tag} />
    <div style="margin-top: 24px;">
      <LogList entries={posts} />
    </div>
  </section>
</Layout>
