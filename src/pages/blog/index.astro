---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import LogList from '../../components/LogList.astro';
import TagChips from '../../components/TagChips.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    date: post.data.date,
    title: post.data.title,
    href: `/blog/${post.id}/`,
  }));
---

<Layout title="Log — doost.io" description="Software, homelab, and woodworking project notes.">
  <section aria-label="All posts">
    <SectionLabel text="log" />
    {tags.length > 0 && <TagChips tags={tags} />}
    <div style="margin-top: 24px;">
      <LogList entries={posts} />
    </div>
  </section>
</Layout>
